# 默认文本文件统一使用 LF
* text=auto eol=lf

# C/C++/嵌入式源码
*.c      text eol=lf
*.h      text eol=lf
*.cpp    text eol=lf
*.hpp    text eol=lf
*.s      text eol=lf
*.S      text eol=lf
*.ld     text eol=lf
*.cmake  text eol=lf
CMakeLists.txt text eol=lf

# 脚本
*.sh     text eol=lf
*.py     text eol=lf

# Windows 脚本保留 CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# 文档
*.md     text eol=lf
*.txt    text eol=lf

# 二进制文件，不做换行转换
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.7z     binary
*.bin    binary
*.elf    binary
*.hex    text eol=lf
*.a      binary
*.lib    binary
*.dll    binary
*.exe    binary