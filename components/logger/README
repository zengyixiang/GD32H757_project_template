使用方法：

    DEBUG_RAW(fmt, ...)      // 打印无头信息的原始调试信息
    DEBUG_E(fmt, ...)        // 打印错误级别调试信息
    DEBUG_E_HEX(data, len)   // 打印错误级别十六进制调试信息
    DEBUG_W(fmt, ...)        // 打印警告级别调试信息
    DEBUG_W_HEX(data, len)   // 打印警告级别十六进制调试信息
    DEBUG_I(fmt, ...)        // 打印信息级别调试信息
    DEBUG_I_HEX(data, len)   // 打印信息级别十六进制调试信息
    DEBUG_D(fmt, ...)        // 打印调试级别调试信息
    DEBUG_D_HEX(data, len)   // 打印调试级别十六进制调试信息

在使用日志宏的源文件中，应先定义本文件自己的日志等级，再包含 `debug.h` 或 `log.h`：

    #define DEBUG_PRINTF 1
    #define DEBUG_LEVEL LVL_DEBUG
    #include "debug.h"

平台适配示例：

    void print_c(char *str, debug_printf_len_t size)
    {
        HAL_UART_Transmit(&huart1, (uint8_t *)str, size, 100);
    }

    debug_critical_t enter_critical(void)
    {
        taskENTER_CRITICAL();
        return 0;
    }

    void exit_critical(debug_critical_t state)
    {
        (void)state;
        taskEXIT_CRITICAL();
    }

    debug_time_t get_time_ms(void)
    {
        return xTaskGetTickCount() * portTICK_PERIOD_MS;
    }

    int main(void)
    {
        unsigned char data[] = {0xDE, 0xAD, 0xBE, 0xEF};

        debug_init(print_c, enter_critical, exit_critical, get_time_ms);

        DEBUG_RAW("原始调试信息，无日志头。\r\n");
        DEBUG_D("调试信息，数值：%d", 42);
        DEBUG_D_HEX(data, sizeof(data));
        DEBUG_I("普通信息，数值：%d", 42);
        DEBUG_W("警告信息，数值：%d", 42);
        DEBUG_E("错误信息，时间：%u", (unsigned int)get_time_ms());

        while(1) {
            debug_log_flush();
        }
    }

常用配置：

    #define DEBUG_PRINTF 0              // 关闭所有调试输出
    #define DEBUG_USE_LIBC 1            // 使用工具链自带 libc 格式化和内存函数
    #define DEBUG_FORCE_INLINE 1        // 在 GCC/Clang 下强制内联小函数
    #define DEBUG_USE_COLOR 0           // 关闭 ANSI 颜色码
    #define DEBUG_PRINT_VERSION 0       // debug_init 时不打印版本信息
    #define DEBUG_ENABLE_FLOAT 0        // 关闭自研格式化器的浮点支持
    #define DEBUG_FLUSH_MAX_PER_CALL 1  // 每次 debug_log_flush 最多输出 1 条；0 表示全部输出

注意：`DEBUG_USE_LIBC` 会影响 `debug.c` 的编译，需要在工程编译选项中定义。单片机上如果串口慢、RTOS 任务多，建议关闭颜色输出，并按任务调度节奏设置 `DEBUG_FLUSH_MAX_PER_CALL`。

类型配置：

    #define DEBUG_U32_USE_UNSIGNED_LONG 1  // 当 SDK 的 uint32_t 实际是 unsigned long 时使用

也可以直接指定完整类型：

    #define DEBUG_U8_TYPE unsigned char
    #define DEBUG_U16_TYPE unsigned short int
    #define DEBUG_U32_TYPE unsigned long
    #define DEBUG_CRITICAL_TYPE DEBUG_U32_TYPE
    #define DEBUG_TIME_TYPE DEBUG_U32_TYPE
    #define DEBUG_PRINTF_LEN_TYPE int

GD32 或部分 ARM SDK 如果 `debug_init(print, enter_critical, exit_critical, get_tick)` 报函数指针类型警告，通常在工程编译宏中添加 `DEBUG_U32_USE_UNSIGNED_LONG=1` 即可。

输出示例：

    ****** DEBUG_VERSION = 1.0.6 ******
    原始调试信息，无日志头。
    (26722445)[D:main.c:47]:调试信息，数值：42
    (26722445)[D:main.c:48]:HEX(4):DE AD BE EF
    (26722445)[I:main.c:49]:普通信息，数值：42
    (26722445)[W:main.c:50]:警告信息，数值：42
    (26722445)[E:main.c:51]:错误信息，时间：26722445
